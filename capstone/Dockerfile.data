# ============================================================
# Data Pipeline Container
# ============================================================
# Runs the data pipeline: fetch → preprocess → merge → feature engineering.
#
# Build:
#   docker build -f Dockerfile.data -t wfp-data-pipeline .
#
# Run locally:
#   docker run -v $(pwd)/data:/app/data -v $(pwd)/logs:/app/logs \
#     -e FEWSNET_USER=xxx -e FEWSNET_PWD=xxx \
#     -e ACLED_EMAIL=xxx -e ACLED_PWD=xxx \
#     wfp-data-pipeline
#
# Run specific countries:
#   docker run -v $(pwd)/data:/app/data -v $(pwd)/logs:/app/logs \
#     -e FEWSNET_USER=xxx -e FEWSNET_PWD=xxx \
#     -e ACLED_EMAIL=xxx -e ACLED_PWD=xxx \
#     wfp-data-pipeline \
#     poetry run python scripts/run_data_pipeline.py --countries cmr nga
# ============================================================

FROM python:3.12-slim

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    curl \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Install AWS CLI v2
RUN curl -s "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && /tmp/aws/install \
    && rm -rf /tmp/aws /tmp/awscliv2.zip

# Install poetry
ENV POETRY_HOME="/opt/poetry"
ENV PATH="$POETRY_HOME/bin:$PATH"
RUN pip install --no-cache-dir poetry

WORKDIR /app

# Copy dependency files first (for layer caching)
COPY pyproject.toml poetry.lock ./

# Install dependencies (pandas, requests, openpyxl, pyjwt, scipy)
RUN poetry config virtualenvs.create true \
    && poetry config virtualenvs.in-project true \
    && poetry install --no-interaction --no-ansi --no-root

# Copy pipeline code
COPY scripts/fetch/ scripts/fetch/
COPY scripts/preprocessing/ scripts/preprocessing/
COPY scripts/merge/ scripts/merge/
COPY scripts/feature_engineering/ scripts/feature_engineering/
COPY scripts/reports/generate_data_inventory.py scripts/reports/generate_data_inventory.py
COPY scripts/run_data_pipeline.py scripts/run_data_pipeline.py
COPY scripts/entrypoint_data.sh scripts/entrypoint_data.sh
RUN chmod +x scripts/entrypoint_data.sh

# Create directory structure
RUN mkdir -p data/raw data/processed data/standardized data/joined data/feature_engineering logs reports

ENTRYPOINT ["scripts/entrypoint_data.sh"]
